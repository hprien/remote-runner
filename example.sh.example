curl -X POST http://127.0.0.1:8000/run \
-H "Authorization: Bearer your-secret-api-key-here" \
-H "Content-Type: application/json" \
-d '{                                                                                                                                                                                                                  
      "script_name": "hello",
      "script_response_webhook": "https://webhook.site/<id>",
      "script_timeout_seconds": 60
    }'